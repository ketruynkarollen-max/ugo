{
  "version": 2,
  "rewrites": [
    { "source": "/analytics-empresa", "destination": "/analytics-empresa.html" },
    { "source": "/analytics-empresa/", "destination": "/analytics-empresa.html" },
    { "source": "/analytics", "destination": "/analytics.html" },
    { "source": "/termos-de-uso", "destination": "/termos-de-uso.html" },
    { "source": "/politica-de-privacidade", "destination": "/politica-de-privacidade.html" }
  ],
  "headers": [
    {
      "source": "/(.*\\.png|.*\\.jpg|.*\\.jpeg|.*\\.webp|.*\\.avif|.*\\.gif|.*\\.svg|.*\\.ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.mp4|.*\\.webm|.*\\.mp3)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/(.*\\.js|.*\\.css)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
